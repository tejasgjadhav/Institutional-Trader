# Copy this file to `.env` and fill in your values. NEVER commit `.env` (it is gitignored).
#
# REQUIRED — Upstox read-only Analytics token (data feed). The system is PAPER-only and
# never places orders, so a trading token is NOT required.
UPSTOX_ANALYTICS_TOKEN=
UPSTOX_ANALYTICS_TOKEN_ISSUED_AT=

# OPTIONAL — signal alerts. Leave blank to disable a channel.
# Telegram bot (free): create a bot via @BotFather, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CallMeBot (free WhatsApp / phone-call alerts).
CALLMEBOT_WHATSAPP_PHONE=
CALLMEBOT_WHATSAPP_APIKEY=
CALLMEBOT_CALL_PHONE=

# Twilio (paid SMS/voice) — optional alternative.
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
TWILIO_TO=
